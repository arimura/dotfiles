{
  "model": "opus",
  "permissions" : {
    "allow" : [
      "Read(~/ghq/github.com/InteractiveAdvertisingBureau)",
      "Edit(./buf.local.md)",
      "Edit(./docs.local)",
      "Edit(./tmp.local)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(git log *)",
      "Bash(grep *)",
      "Bash(which *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun simctl list *)",
      "Bash(xcrun simctl install *)",
      "Bash(xcrun simctl launch *)",
      "Bash(xcodegen *)",
      "Bash(pod install)",
      "Bash(set -o pipefail)",
      "Bash(bundle exec xcpretty)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
