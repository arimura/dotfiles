{
  "model": "opus",
  "permissions" : {
    "allow" : [
      "Read(~/ghq/github.com/InteractiveAdvertisingBureau)",
      "Edit(./buf.local.md)",
      "Edit(./docs.local)",
      "Edit(./tmp.local)",
      "Bash(ls *)",
