{
  "model": "opus",
  "permissions" : {
    "allow" : [
      "Read(~/ghq/github.com/InteractiveAdvertisingBureau)",
      "Edit(./buf.local.md)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(git log *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun simctl list devices booted)",
      "Bash(xcrun simctl install *)",
      "Bash(xcrun simctl launch *)",
      "Bash(xcodegen *)",
      "Bash(pod install)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
